{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Manager Local",
  "version": "0.1.0",
  "identifier": "com.managerlocal.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [{
      "title": "Manager Local",
      "width": 1180,
      "height": 760,
      "minWidth": 920,
      "minHeight": 650,
      "decorations": false,
      "transparent": true,
      "resizable": true
    }],
    "security": { "csp": null }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
